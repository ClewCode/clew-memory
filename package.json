{
  "name": "clew-memory",
  "version": "0.1.0",
  "description": "Standalone MCP Memory Layer for AI coding agents using local SQLite, FTS5, sqlite-vec, and Transformers.js embeddings.",
  "type": "module",
  "bin": {
    "clew-memory": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "latest",
    "@xenova/transformers": "latest",
    "better-sqlite3": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "sqlite-vec": "latest",
    "ulid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "bun-types": "^1.3.14",
    "drizzle-kit": "latest",
    "typescript": "latest"
  }
}
