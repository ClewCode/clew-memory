{
  "name": "clew-memory",
  "version": "0.1.0",
  "description": "Standalone MCP Memory Layer for AI coding agents using local SQLite, FTS5, sqlite-vec, and Transformers.js embeddings.",
  "type": "module",
  "bin": {
    "clew-memory": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "node dist/index.js",
    "build": "bun build src/index.ts --target node --external better-sqlite3 --external sqlite-vec --external @xenova/transformers --external onnxruntime-node --outdir dist",
    "prepack": "bun run build",
    "prepublishOnly": "bun run lint && bunx tsc --noEmit",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "latest",
    "@xenova/transformers": "latest",
    "better-sqlite3": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "sqlite-vec": "latest",
    "ulid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "bun-types": "^1.3.14",
    "drizzle-kit": "latest",
    "typescript": "latest"
  }
}
